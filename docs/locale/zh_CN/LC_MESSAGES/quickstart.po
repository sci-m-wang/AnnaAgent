#: ../../en/quickstart.rst:2
msgid "Quickstart"
msgstr "快速开始"

#: ../../en/quickstart.rst:4
msgid "This guide starts from a clean machine and ends with a working AnnaAgent CLI workspace. It uses the base model path because it has the lowest setup cost."
msgstr "本页从一台干净机器开始，带你完成安装、创建 workspace、配置模型并运行样例。为了降低门槛，默认使用 base model 路径。"

#: ../../en/quickstart.rst:8
msgid "Prerequisites"
msgstr "准备条件"

#: ../../en/quickstart.rst:10
msgid "Python 3.10 or newer."
msgstr "Python 3.10 或更新版本。"

#: ../../en/quickstart.rst:11
msgid "One package runner: ``uv``, ``pipx``, or ``pip``."
msgstr "``uv``、``pipx`` 或 ``pip`` 之一。"

#: ../../en/quickstart.rst:12
msgid "An OpenAI-compatible chat model endpoint and API key."
msgstr "一个 OpenAI-compatible chat model endpoint 和 API key。"

#: ../../en/quickstart.rst:13
msgid "An OpenAI-compatible embedding endpoint if you plan to use memory indexing."
msgstr "如果要使用长期记忆，还需要一个 OpenAI-compatible embedding endpoint。"

#: ../../en/quickstart.rst:16
msgid "Install the CLI"
msgstr "安装 CLI"

#: ../../en/quickstart.rst:18
msgid "Install from PyPI as a standalone command:"
msgstr "推荐从 PyPI 安装成独立终端命令："

#: ../../en/quickstart.rst:25
msgid "If you use ``pipx`` instead:"
msgstr "如果使用 ``pipx``："

#: ../../en/quickstart.rst:32
msgid "For source development:"
msgstr "如果你要从源码开发："

#: ../../en/quickstart.rst:42
msgid "Create a Workspace"
msgstr "创建 Workspace"

#: ../../en/quickstart.rst:44
msgid "AnnaAgent keeps user configuration, secrets, sample cases, runs, logs, and memory files inside a workspace directory."
msgstr "AnnaAgent 会把用户配置、密钥、样例案例、运行结果、日志和记忆库放在 workspace 中："

#: ../../en/quickstart.rst:52
msgid "The generated workspace contains:"
msgstr "生成结构如下："

#: ../../en/quickstart.rst:69
msgid "Configure the Backbone Model"
msgstr "配置 Backbone 模型"

#: ../../en/quickstart.rst:71
msgid "Use the wizard for interactive setup:"
msgstr "使用交互式向导："

#: ../../en/quickstart.rst:79
msgid "Or set non-secret values directly:"
msgstr "也可以用非交互命令设置非密钥字段："

#: ../../en/quickstart.rst:88
msgid "Select the Lightweight Model Path"
msgstr "选择轻量模式"

#: ../../en/quickstart.rst:90
msgid "For a first run, use the base model for all auxiliary modules:"
msgstr "第一次运行建议让所有模块都使用 base model："

